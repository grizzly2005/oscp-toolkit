    {
      "name": "nmap",
      "category": "Enumeration",
      "tags": [
        "network",
        "scan"
      ],
      "path": "/usr/bin/nmap",
      "os_target": "multi",
      "description": "Network mapper / port scanner",
      "dependencies": [],
      "templates": [
        "nmap -sT -sC -sV -oN \"$OSCP_NMAP/{{IP}}_tcp_connect.txt\" {{IP}}",
        "sudo nmap -A -oN \"$OSCP_NMAP/{{IP}}_advanced_root.txt\" {{IP}}",
        "sudo nmap -p- -sS -sU --min-rate 1000 --max-retries 1 -T4 -oN \"$OSCP_NMAP/{{IP}}_fast_tcp_udp_root.txt\" {{IP}}",
        "nmap -sT -p- -T4 -n -Pn -oN \"$OSCP_NMAP/{{IP}}_fast_ports_connect.txt\" {{IP}}",
        "sudo nmap --min-rate 5000 -p- -vvv -Pn -n -oG \"$OSCP_NMAP/{{IP}}_openPorts_root.gnmap\" {{IP}}",
        "nmap -sT -p- -oN \"$OSCP_NMAP/{{IP}}_all_ports_connect.txt\" {{IP}}",
        "nmap -sT --top-ports {{TOP_PORTS}} -oN \"$OSCP_NMAP/{{IP}}_top_{{TOP_PORTS}}.txt\" {{IP}}",
        "sudo nmap -sU --top-ports 100 -oN \"$OSCP_UDP/{{IP}}_udp_top100_root.txt\" {{IP}}",
        "nmap -sT -sC -sV -p {{PORTS}} -oN \"$OSCP_SERVICES/{{IP}}_targeted.txt\" {{IP}}",
        "nmap -sT --script=smb-vuln* -p 445 -oN \"$OSCP_SERVICES/{{IP}}_smb_vulns.txt\" {{IP}}",
        "nmap -sT --script=ldap* -p 389,636 -oN \"$OSCP_SERVICES/{{IP}}_ldap.txt\" {{IP}}"
      ],
      "doc_link": "cheatsheets/nmap.md",
